# Loom v3 Configuration
# Copy to .env and fill in values

# === Required ===

# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=

# LLM API key (one required based on LLM_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Optional ===

# LLM provider: "openai" (default) or "anthropic"
# LLM_PROVIDER=openai

# Model override (defaults: gpt-4o-mini for OpenAI, claude-sonnet-4-20250514 for Anthropic)
# LLM_MODEL=gpt-4o-mini

# Server config (defaults work for Fly.io)
# PORT=3000
# HOST=0.0.0.0

# Doctrine directory (default: ./doctrine)
# DOCTRINE_DIR=./doctrine
